---
const {
  title,
  description,
  href,
  image,
  date,
  displayDate,
  tags = [],
  variant = "recent",
} = Astro.props;
---

<a class={`blog-card blog-card--${variant}`} href={href}>
  <div class="blog-card__image-wrap">
    <img src={image} alt={title} class="blog-card__image" />
  </div>

  <div class="blog-card__content">
    {variant === "featured" ? (
      <div class="blog-card__label">Featured</div>
    ) : null}

    <p class="blog-card__date">{displayDate ?? date}</p>
    <h2 class="blog-card__title">{title}</h2>
    <p class="blog-card__description">{description}</p>

    {tags.length > 0 ? (
      <div class="blog-card__tags">
        {tags.map((tag) => (
          <span class="blog-card__tag">{tag}</span>
        ))}
      </div>
    ) : null}
  </div>
</a>

<style>
  .blog-card {
    display: grid;
    color: inherit;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(38, 78, 65, 0.12);
    border-radius: 1.15rem;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease,
      border-color 0.2s ease;
    backdrop-filter: blur(4px);
  }

  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
    border-color: rgba(38, 78, 65, 0.2);
  }

  .blog-card * {
    text-decoration: none;
  }

  .blog-card--featured {
    grid-template-columns: 1.15fr 1fr;
    min-height: 420px;
  }

  .blog-card--recent {
    grid-template-columns: 320px minmax(0, 1fr);
    min-height: 240px;
  }

  .blog-card__image-wrap {
    height: 100%;
    overflow: hidden;
  }

  .blog-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card--featured .blog-card__image {
    min-height: 420px;
  }

  .blog-card--recent .blog-card__image {
    min-height: 240px;
  }

  .blog-card__content {
    padding: 1.5rem 1.6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .blog-card--featured .blog-card__content {
    padding: 1.75rem;
  }

  .blog-card__label {
    display: inline-block;
    align-self: flex-start;
    margin-bottom: 0.55rem;
    padding: 0.28rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 999px;
    background: rgba(38, 78, 65, 0.08);
    color: #264e41;
    border: 1px solid rgba(38, 78, 65, 0.2);
  }

  .blog-card__date {
    margin: 0 0 0.45rem;
    font-size: 0.9rem;
    color: #5f6b76;
  }

  .blog-card__title {
    margin: 0.45rem 0 0.75rem;
    color: #16342d;
    line-height: 1.15;
  }

  .blog-card--featured .blog-card__title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    max-width: 15ch;
  }

  .blog-card--recent .blog-card__title {
    font-size: 1.55rem;
    line-height: 1.25;
    max-width: 30ch;
  }

  .blog-card__description {
    margin: 0;
    font-size: 1.03rem;
    line-height: 1.65;
    color: #24313b;
  }

  .blog-card__tags {
    margin-top: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .blog-card__tag {
    padding: 0.28rem 0.55rem;
    border: 1px solid rgba(38, 78, 65, 0.2);
    border-radius: 999px;
    font-size: 0.75rem;
    line-height: 1;
    color: #264e41;
    background: rgba(38, 78, 65, 0.04);
  }

  @media (max-width: 900px) {
    .blog-card--featured,
    .blog-card--recent {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .blog-card--featured .blog-card__image {
      min-height: 260px;
      height: 260px;
    }

    .blog-card--recent .blog-card__image {
      min-height: 230px;
      height: 230px;
    }
  }

  @media (max-width: 768px) {
    .blog-card__content {
      padding: 1.3rem;
    }

    .blog-card--recent .blog-card__title {
      font-size: 1.35rem;
    }
  }
</style>