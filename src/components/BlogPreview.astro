---
import { featuredPost, recentPosts } from "../data/blogPosts";
---

<section class="blog-section" id="blog">
  <div class="blog-wrap">
    <div class="blog-header">
      <h2>Blog</h2>
      <p>
        Notes on research administration tooling, workflow design, and practical
        systems thinking.
      </p>
    </div>

    <!-- Featured -->
    <a href={featuredPost.href} class="card-link-wrap featured-link">
      <article class="featured-card">
        <div class="featured-top">
          <span class="featured-badge">Featured</span>
          <span class="meta">
            {featuredPost.displayDate ?? featuredPost.date}
          </span>
        </div>

        <h3>{featuredPost.title}</h3>
        <p>{featuredPost.description}</p>
        <span class="read-link">Read article →</span>
      </article>
    </a>

    <!-- Recent -->
    <div class="blog-grid">
      {recentPosts.slice(0, 3).map((post) => (
        <a href={post.href} class="card-link-wrap">
          <article class="blog-card">
            <div class="meta">
              {post.displayDate ?? post.date}
            </div>

            <h4>{post.title}</h4>
            <p>{post.description}</p>

            <span class="read-link">Read article →</span>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  * {
    box-sizing: border-box;
  }

  .blog-section {
    width: 100%;
    padding: 120px 24px;
    background: #ffffff;
  }

  .blog-wrap {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .blog-header h2 {
    margin: 0 0 14px 0;
    font-family: Cambria, Georgia, "Times New Roman", serif;
    font-size: 2.5rem;
    line-height: 1.1;
    color: #1f2933;
  }

  .blog-header p {
    margin: 0 auto;
    max-width: 760px;
    color: #6b7280;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .card-link-wrap {
    display: block;
    width: 100%;
    text-decoration: none !important;
    color: inherit;
  }

  .card-link-wrap * {
    text-decoration: none !important;
  }

  .featured-link {
    margin-bottom: 36px;
  }

  .featured-card {
    width: 100%;
    padding: 36px;
    border-radius: 22px;
    background: linear-gradient(
      135deg,
      #f8f7f2 0%,
      #f2f4f3 52%,
      #f4f6f8 100%
    );
    border: 1px solid rgba(31, 41, 51, 0.08);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .card-link-wrap:hover .featured-card {
    transform: translateY(-4px);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.08);
    border-color: rgba(42, 92, 154, 0.18);
  }

  .featured-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, #2e6f5e, #2a5c9a);
    color: #ffffff;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .featured-card h3 {
    margin: 0 0 14px 0;
    font-size: 1.8rem;
    line-height: 1.25;
    color: #1f2933;
    transition: color 0.22s ease;
  }

  .card-link-wrap:hover .featured-card h3 {
    color: #163b67;
  }

  .featured-card p {
    margin: 0 0 18px 0;
    max-width: 880px;
    color: #4b5563;
    line-height: 1.8;
    font-size: 1.04rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    width: 100%;
  }

  .blog-card {
    height: 100%;
    padding: 26px;
    border-radius: 18px;
    background: #fcfbf8;
    border: 1px solid rgba(31, 41, 51, 0.08);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease,
      background 0.22s ease;
  }

  .card-link-wrap:hover .blog-card {
    transform: translateY(-4px);
    box-shadow: 0 16px 28px rgba(0, 0, 0, 0.07);
    border-color: rgba(42, 92, 154, 0.18);
    background: #ffffff;
  }

  .blog-card h4 {
    margin: 10px 0 12px 0;
    font-size: 1.2rem;
    line-height: 1.35;
    color: #1f2933;
    transition: color 0.22s ease;
  }

  .card-link-wrap:hover .blog-card h4 {
    color: #2a5c9a;
  }

  .blog-card p {
    margin: 0 0 14px 0;
    font-size: 0.98rem;
    line-height: 1.75;
    color: #4b5563;
  }

  .meta {
    font-size: 0.86rem;
    color: #7b8794;
  }

  .read-link {
    display: inline-flex;
    align-items: center;
    color: #2a5c9a;
    font-weight: 600;
    transition: transform 0.22s ease, color 0.22s ease;
  }

  .card-link-wrap:hover .read-link {
    color: #1d4f86;
    transform: translateX(2px);
  }

  @media (max-width: 980px) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .featured-card {
      padding: 30px;
    }
  }

  @media (max-width: 720px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .featured-card,
    .blog-card {
      padding: 24px;
    }
  }
</style>