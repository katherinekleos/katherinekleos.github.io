---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  type?: string;
  status?: string;
  lastUpdated?: string;
  featured?: boolean;
}

const {
  title,
  description,
  href,
  image,
  type = "Tool",
  status,
  lastUpdated,
  featured = false,
} = Astro.props;
---

<a class={`tool-card ${featured ? "featured" : ""}`} href={href}>
  {image && (
    <div class="tool-card-image-wrap">
      <img src={image} alt={title} class="tool-card-image" loading="lazy" />
    </div>
  )}

  <div class="tool-card-content">
    <div class="tool-card-pills">
      <span class="tool-pill">{type}</span>
      {status && <span class="status-pill">{status}</span>}
    </div>

    <h2 class="tool-card-title">{title}</h2>

    {lastUpdated && (
      <p class="tool-card-date">Last updated: {lastUpdated}</p>
    )}

    <p class="tool-card-description">{description}</p>

    <span class="tool-card-link">
      Open Tool <span aria-hidden="true">→</span>
    </span>
  </div>
</a>

<style>
  .tool-card {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(38, 78, 65, 0.12);
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 18px 40px rgba(21, 37, 31, 0.08);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      border-color 0.22s ease;
    min-height: 100%;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px rgba(21, 37, 31, 0.12);
    border-color: rgba(38, 78, 65, 0.2);
  }

  .tool-card-image-wrap {
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background: linear-gradient(135deg, #edf4f1 0%, #dce9e4 100%);
  }

  .tool-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tool-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.4rem 1.35rem 1.45rem;
  }

  .tool-card-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tool-pill,
  .status-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.34rem 0.78rem;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .tool-pill {
    background: rgba(38, 78, 65, 0.1);
    color: #264e41;
  }

  .status-pill {
    background: rgba(76, 108, 140, 0.1);
    color: #385270;
  }

  .tool-card-title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    color: #17352d;
  }

  .tool-card-date {
    margin: 0;
    font-size: 0.92rem;
    color: #5d6f68;
  }

  .tool-card-description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: #31443d;
  }

  .tool-card-link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 600;
    color: #264e41;
    padding-top: 0.25rem;
  }

  .featured {
    grid-template-columns: 1.15fr 1fr;
  }

  .featured .tool-card-content {
    padding: 1.7rem 1.6rem;
    gap: 0.85rem;
  }

  .featured .tool-card-title {
    font-size: clamp(1.6rem, 2vw, 2rem);
  }

  .featured .tool-card-description {
    font-size: 1.03rem;
  }

  @media (max-width: 900px) {
    .featured {
      grid-template-columns: 1fr;
    }
  }
</style>