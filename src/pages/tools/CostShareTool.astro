<section class="tool-shell">
  <div class="tool-hero">
    <p class="tool-eyebrow">Tools &amp; Templates</p>
    <h1>Cost Share Calculator</h1>
    <p class="tool-intro">
      Plan salary cap distributions across fiscal years and review adjustment scenarios in one place.
    </p>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Project Details</h2>
      <p>Enter the project dates to generate the fiscal year breakdown automatically.</p>
    </div>

    <div class="input-grid">
      <label class="field">
        <span>Project start date</span>
        <input id="projectStart" type="date" />
      </label>

      <label class="field">
        <span>Project end date</span>
        <input id="projectEnd" type="date" />
      </label>
    </div>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Key Inputs</h2>
      <p>These values drive the salary cap and cost share calculations for each generated fiscal year.</p>
    </div>

    <div class="input-grid input-grid-3">
      <label class="field">
        <span>Base salary</span>
        <input id="baseSalary" type="number" min="0" step="0.01" placeholder="100000" />
      </label>

      <label class="field">
        <span>Annual salary growth %</span>
        <input id="salaryGrowth" type="number" step="0.01" placeholder="3" />
      </label>

      <label class="field">
        <span>Total LOE %</span>
        <input id="totalLoe" type="number" min="0" max="100" step="0.01" placeholder="20" />
      </label>

      <label class="field">
        <span>Fringe rate %</span>
        <input id="fringeRate" type="number" min="0" step="0.01" placeholder="30" />
      </label>

      <label class="field">
        <span>Salary cap</span>
        <input id="salaryCap" type="number" min="0" step="0.01" value="228000" />
      </label>

      <label class="field">
        <span>Name / scenario label</span>
        <input id="scenarioLabel" type="text" placeholder="Optional" />
      </label>
    </div>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Fiscal Year Breakdown</h2>
      <p>
        The online version is dynamic and can generate as many fiscal years as needed based on the
        project dates.
      </p>
    </div>

    <div id="fyEmptyState" class="empty-state">
      Enter a project start and end date to generate the fiscal year table.
    </div>

    <div id="fyTableWrap" class="table-wrap" hidden>
      <table class="results-table">
        <thead>
          <tr>
            <th>Fiscal Year</th>
            <th>Start</th>
            <th>End</th>
            <th>Months</th>
            <th>Proration</th>
          </tr>
        </thead>
        <tbody id="fyTableBody"></tbody>
      </table>
    </div>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Main Cost Share Calculation</h2>
      <p>Grant LOE is capped when salary exceeds the cap. Cost share LOE is the remaining effort.</p>
    </div>

    <div id="calcEmptyState" class="empty-state">
      Enter project dates and key inputs to calculate the fiscal year results.
    </div>

    <div id="calcTableWrap" class="table-wrap" hidden>
      <table class="results-table wide-table">
        <thead>
          <tr>
            <th>FY</th>
            <th>Months</th>
            <th>Proration</th>
            <th>Projected Salary</th>
            <th>Salary Cap</th>
            <th>Total LOE %</th>
            <th>Grant LOE %</th>
            <th>C/S LOE %</th>
            <th>Grant Salary</th>
            <th>Grant Fringe</th>
            <th>C/S Salary</th>
            <th>C/S Fringe</th>
            <th>Total Grant Cost</th>
            <th>Total C/S Cost</th>
          </tr>
        </thead>
        <tbody id="calcTableBody"></tbody>
      </table>
    </div>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Summary</h2>
      <p>High-level totals across all generated fiscal years.</p>
    </div>

    <div id="summaryEmptyState" class="empty-state">
      Summary totals will appear once the calculations are generated.
    </div>

    <div id="summaryGrid" class="summary-grid" hidden>
      <div class="summary-item">
        <span class="summary-label">Total Grant Salary</span>
        <strong id="summaryGrantSalary">$0.00</strong>
      </div>
      <div class="summary-item">
        <span class="summary-label">Total Grant Fringe</span>
        <strong id="summaryGrantFringe">$0.00</strong>
      </div>
      <div class="summary-item">
        <span class="summary-label">Total Cost Share Salary</span>
        <strong id="summaryCssSalary">$0.00</strong>
      </div>
      <div class="summary-item">
        <span class="summary-label">Total Cost Share Fringe</span>
        <strong id="summaryCssFringe">$0.00</strong>
      </div>
      <div class="summary-item">
        <span class="summary-label">Total Grant Cost</span>
        <strong id="summaryGrantCost">$0.00</strong>
      </div>
      <div class="summary-item">
        <span class="summary-label">Total Cost Share Cost</span>
        <strong id="summaryCssCost">$0.00</strong>
      </div>
    </div>
  </div>

  <div class="tool-card">
    <div class="section-heading">
      <h2>Adjustment / Reverse Calculation</h2>
      <p>Select a fiscal year and test a known grant charge or known grant LOE for that year.</p>
    </div>

    <div id="adjustmentEmptyState" class="empty-state">
      Generate the main calculation first to activate the adjustment section.
    </div>

    <div id="adjustmentWrap" hidden>
      <div class="input-grid input-grid-3">
        <label class="field">
          <span>Selected fiscal year</span>
          <select id="adjustFy"></select>
        </label>

        <label class="field">
          <span>Known grant salary</span>
          <input id="knownGrantSalary" type="number" min="0" step="0.01" placeholder="Optional" />
        </label>

        <label class="field">
          <span>Known grant LOE %</span>
          <input id="knownGrantLoe" type="number" min="0" max="100" step="0.01" placeholder="Optional" />
        </label>
      </div>

      <div class="summary-grid adjustment-grid">
        <div class="summary-item">
          <span class="summary-label">Projected Salary</span>
          <strong id="adjProjectedSalary">$0.00</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Proration</span>
          <strong id="adjProration">0.0000</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Grant LOE %</span>
          <strong id="adjGrantLoe">0.00%</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Cost Share LOE %</span>
          <strong id="adjCssLoe">0.00%</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Grant Salary</span>
          <strong id="adjGrantSalary">$0.00</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Grant Fringe</span>
          <strong id="adjGrantFringe">$0.00</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Cost Share Salary</span>
          <strong id="adjCssSalary">$0.00</strong>
        </div>
        <div class="summary-item">
          <span class="summary-label">Reverse Cost Share Fringe</span>
          <strong id="adjCssFringe">$0.00</strong>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const startInput = document.getElementById("projectStart");
  const endInput = document.getElementById("projectEnd");

  const baseSalaryInput = document.getElementById("baseSalary");
  const salaryGrowthInput = document.getElementById("salaryGrowth");
  const totalLoeInput = document.getElementById("totalLoe");
  const fringeRateInput = document.getElementById("fringeRate");
  const salaryCapInput = document.getElementById("salaryCap");

  const fyEmptyState = document.getElementById("fyEmptyState");
  const fyTableWrap = document.getElementById("fyTableWrap");
  const fyTableBody = document.getElementById("fyTableBody");

  const calcEmptyState = document.getElementById("calcEmptyState");
  const calcTableWrap = document.getElementById("calcTableWrap");
  const calcTableBody = document.getElementById("calcTableBody");

  const summaryEmptyState = document.getElementById("summaryEmptyState");
  const summaryGrid = document.getElementById("summaryGrid");

  const summaryGrantSalary = document.getElementById("summaryGrantSalary");
  const summaryGrantFringe = document.getElementById("summaryGrantFringe");
  const summaryCssSalary = document.getElementById("summaryCssSalary");
  const summaryCssFringe = document.getElementById("summaryCssFringe");
  const summaryGrantCost = document.getElementById("summaryGrantCost");
  const summaryCssCost = document.getElementById("summaryCssCost");

  const adjustmentEmptyState = document.getElementById("adjustmentEmptyState");
  const adjustmentWrap = document.getElementById("adjustmentWrap");
  const adjustFySelect = document.getElementById("adjustFy");
  const knownGrantSalaryInput = document.getElementById("knownGrantSalary");
  const knownGrantLoeInput = document.getElementById("knownGrantLoe");

  const adjProjectedSalary = document.getElementById("adjProjectedSalary");
  const adjProration = document.getElementById("adjProration");
  const adjGrantLoe = document.getElementById("adjGrantLoe");
  const adjCssLoe = document.getElementById("adjCssLoe");
  const adjGrantSalary = document.getElementById("adjGrantSalary");
  const adjGrantFringe = document.getElementById("adjGrantFringe");
  const adjCssSalary = document.getElementById("adjCssSalary");
  const adjCssFringe = document.getElementById("adjCssFringe");

  let currentRows = [];

  function parseLocalDate(value) {
    if (!value) return null;
    const [year, month, day] = value.split("-").map(Number);
    return new Date(year, month - 1, day);
  }

  function parseNumber(value) {
    if (value === "" || value === null || value === undefined) return null;
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : null;
  }

  function formatDate(date) {
    return date.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  }

  function formatCurrency(value) {
    return value.toLocaleString("en-US", {
      style: "currency",
      currency: "USD",
    });
  }

  function formatPercent(value) {
    return `${value.toFixed(2)}%`;
  }

  function getFiscalYearLabel(date) {
    const year = date.getMonth() >= 6 ? date.getFullYear() + 1 : date.getFullYear();
    return `FY ${year}`;
  }

  function getFiscalYearStart(date) {
    const year = date.getMonth() >= 6 ? date.getFullYear() : date.getFullYear() - 1;
    return new Date(year, 6, 1);
  }

  function getFiscalYearEnd(date) {
    const fyStart = getFiscalYearStart(date);
    return new Date(fyStart.getFullYear() + 1, 5, 30);
  }

  function addDays(date, days) {
    const next = new Date(date);
    next.setDate(next.getDate() + days);
    return next;
  }

  function monthsBetweenInclusive(start, end) {
    const years = end.getFullYear() - start.getFullYear();
    const months = end.getMonth() - start.getMonth();
    const total = years * 12 + months + 1;
    return total > 0 ? total : 0;
  }

  function generateFiscalYears(projectStart, projectEnd) {
    const rows = [];
    let cursor = new Date(projectStart);

    while (cursor <= projectEnd) {
      const fyStart = getFiscalYearStart(cursor);
      const fyEnd = getFiscalYearEnd(cursor);

      const segmentStart = cursor > fyStart ? cursor : fyStart;
      const segmentEnd = projectEnd < fyEnd ? projectEnd : fyEnd;

      const months = monthsBetweenInclusive(segmentStart, segmentEnd);
      const proration = months / 12;

      rows.push({
        fiscalYear: getFiscalYearLabel(cursor),
        start: new Date(segmentStart),
        end: new Date(segmentEnd),
        months,
        proration,
      });

      cursor = addDays(segmentEnd, 1);
    }

    return rows;
  }

  function renderFiscalYears(rows) {
    fyTableBody.innerHTML = "";

    if (!rows.length) {
      fyEmptyState.hidden = false;
      fyTableWrap.hidden = true;
      fyEmptyState.textContent = "Enter a project start and end date to generate the fiscal year table.";
      return;
    }

    rows.forEach((row) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td>${row.fiscalYear}</td>
        <td>${formatDate(row.start)}</td>
        <td>${formatDate(row.end)}</td>
        <td>${row.months}</td>
        <td>${row.proration.toFixed(4)}</td>
      `;
      fyTableBody.appendChild(tr);
    });

    fyEmptyState.hidden = true;
    fyTableWrap.hidden = false;
  }

  function calculateRows(baseRows, baseSalary, growthPct, totalLoePct, fringePct, salaryCap) {
    const growthRate = growthPct / 100;
    const totalLoe = totalLoePct / 100;
    const fringeRate = fringePct / 100;

    return baseRows.map((row, index) => {
      const projectedSalary = baseSalary * Math.pow(1 + growthRate, index);
      const capRatio = projectedSalary > 0 ? Math.min(1, salaryCap / projectedSalary) : 0;

      const grantLoe = totalLoe * capRatio;
      const cssLoe = totalLoe - grantLoe;

      const grantSalary = projectedSalary * grantLoe * row.proration;
      const grantFringe = grantSalary * fringeRate;

      const cssSalary = projectedSalary * cssLoe * row.proration;
      const cssFringe = cssSalary * fringeRate;

      return {
        ...row,
        projectedSalary,
        salaryCap,
        totalLoePct,
        grantLoePct: grantLoe * 100,
        cssLoePct: cssLoe * 100,
        grantSalary,
        grantFringe,
        cssSalary,
        cssFringe,
        totalGrantCost: grantSalary + grantFringe,
        totalCssCost: cssSalary + cssFringe,
      };
    });
  }

  function renderCalculation(rows) {
    calcTableBody.innerHTML = "";

    if (!rows.length) {
      calcEmptyState.hidden = false;
      calcTableWrap.hidden = true;
      return;
    }

    rows.forEach((row) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td>${row.fiscalYear}</td>
        <td>${row.months}</td>
        <td>${row.proration.toFixed(4)}</td>
        <td>${formatCurrency(row.projectedSalary)}</td>
        <td>${formatCurrency(row.salaryCap)}</td>
        <td>${formatPercent(row.totalLoePct)}</td>
        <td>${formatPercent(row.grantLoePct)}</td>
        <td>${formatPercent(row.cssLoePct)}</td>
        <td>${formatCurrency(row.grantSalary)}</td>
        <td>${formatCurrency(row.grantFringe)}</td>
        <td>${formatCurrency(row.cssSalary)}</td>
        <td>${formatCurrency(row.cssFringe)}</td>
        <td>${formatCurrency(row.totalGrantCost)}</td>
        <td>${formatCurrency(row.totalCssCost)}</td>
      `;
      calcTableBody.appendChild(tr);
    });

    calcEmptyState.hidden = true;
    calcTableWrap.hidden = false;
  }

  function renderSummary(rows) {
    if (!rows.length) {
      summaryEmptyState.hidden = false;
      summaryGrid.hidden = true;
      return;
    }

    const totals = rows.reduce(
      (acc, row) => {
        acc.grantSalary += row.grantSalary;
        acc.grantFringe += row.grantFringe;
        acc.cssSalary += row.cssSalary;
        acc.cssFringe += row.cssFringe;
        acc.grantCost += row.totalGrantCost;
        acc.cssCost += row.totalCssCost;
        return acc;
      },
      {
        grantSalary: 0,
        grantFringe: 0,
        cssSalary: 0,
        cssFringe: 0,
        grantCost: 0,
        cssCost: 0,
      }
    );

    summaryGrantSalary.textContent = formatCurrency(totals.grantSalary);
    summaryGrantFringe.textContent = formatCurrency(totals.grantFringe);
    summaryCssSalary.textContent = formatCurrency(totals.cssSalary);
    summaryCssFringe.textContent = formatCurrency(totals.cssFringe);
    summaryGrantCost.textContent = formatCurrency(totals.grantCost);
    summaryCssCost.textContent = formatCurrency(totals.cssCost);

    summaryEmptyState.hidden = true;
    summaryGrid.hidden = false;
  }

  function populateAdjustmentDropdown(rows) {
    adjustFySelect.innerHTML = "";

    rows.forEach((row, index) => {
      const option = document.createElement("option");
      option.value = String(index);
      option.textContent = row.fiscalYear;
      adjustFySelect.appendChild(option);
    });

    adjustmentEmptyState.hidden = rows.length > 0;
    adjustmentWrap.hidden = rows.length === 0;
  }

  function renderAdjustment() {
    if (!currentRows.length) {
      adjustmentEmptyState.hidden = false;
      adjustmentWrap.hidden = true;
      return;
    }

    const selectedIndex = Number(adjustFySelect.value || 0);
    const row = currentRows[selectedIndex];
    if (!row) return;

    const fringePct = parseNumber(fringeRateInput.value) ?? 0;
    const fringeRate = fringePct / 100;
    const totalLoePct = parseNumber(totalLoeInput.value) ?? 0;

    const knownGrantSalary = parseNumber(knownGrantSalaryInput.value);
    const knownGrantLoe = parseNumber(knownGrantLoeInput.value);

    let reverseGrantLoePct = row.grantLoePct;
    let reverseGrantSalary = row.grantSalary;

    if (knownGrantSalary !== null && row.projectedSalary > 0 && row.proration > 0) {
      reverseGrantSalary = knownGrantSalary;
      reverseGrantLoePct = (knownGrantSalary / (row.projectedSalary * row.proration)) * 100;
    } else if (knownGrantLoe !== null) {
      reverseGrantLoePct = knownGrantLoe;
      reverseGrantSalary = row.projectedSalary * (knownGrantLoe / 100) * row.proration;
    }

    const reverseCssLoePct = Math.max(totalLoePct - reverseGrantLoePct, 0);
    const reverseCssSalary = row.projectedSalary * (reverseCssLoePct / 100) * row.proration;

    const reverseGrantFringe = reverseGrantSalary * fringeRate;
    const reverseCssFringe = reverseCssSalary * fringeRate;

    adjProjectedSalary.textContent = formatCurrency(row.projectedSalary);
    adjProration.textContent = row.proration.toFixed(4);
    adjGrantLoe.textContent = formatPercent(reverseGrantLoePct);
    adjCssLoe.textContent = formatPercent(reverseCssLoePct);
    adjGrantSalary.textContent = formatCurrency(reverseGrantSalary);
    adjGrantFringe.textContent = formatCurrency(reverseGrantFringe);
    adjCssSalary.textContent = formatCurrency(reverseCssSalary);
    adjCssFringe.textContent = formatCurrency(reverseCssFringe);
  }

  function resetCalculationViews() {
    currentRows = [];
    calcTableBody.innerHTML = "";
    calcEmptyState.hidden = false;
    calcTableWrap.hidden = true;

    summaryEmptyState.hidden = false;
    summaryGrid.hidden = true;

    adjustmentEmptyState.hidden = false;
    adjustmentWrap.hidden = true;
    adjustFySelect.innerHTML = "";
  }

  function updateTool() {
    const projectStart = parseLocalDate(startInput.value);
    const projectEnd = parseLocalDate(endInput.value);

    if (!projectStart || !projectEnd) {
      fyTableBody.innerHTML = "";
      fyEmptyState.hidden = false;
      fyTableWrap.hidden = true;
      fyEmptyState.textContent = "Enter a project start and end date to generate the fiscal year table.";
      resetCalculationViews();
      return;
    }

    if (projectEnd < projectStart) {
      fyTableBody.innerHTML = "";
      fyEmptyState.hidden = false;
      fyTableWrap.hidden = true;
      fyEmptyState.textContent = "Project end date must be on or after the project start date.";
      resetCalculationViews();
      return;
    }

    const baseRows = generateFiscalYears(projectStart, projectEnd);
    renderFiscalYears(baseRows);

    const baseSalary = parseNumber(baseSalaryInput.value);
    const growthPct = parseNumber(salaryGrowthInput.value);
    const totalLoePct = parseNumber(totalLoeInput.value);
    const fringePct = parseNumber(fringeRateInput.value);
    const salaryCap = parseNumber(salaryCapInput.value);

    const hasCalcInputs =
      baseSalary !== null &&
      growthPct !== null &&
      totalLoePct !== null &&
      fringePct !== null &&
      salaryCap !== null;

    if (!hasCalcInputs) {
      resetCalculationViews();
      return;
    }

    currentRows = calculateRows(
      baseRows,
      baseSalary,
      growthPct,
      totalLoePct,
      fringePct,
      salaryCap
    );

    renderCalculation(currentRows);
    renderSummary(currentRows);
    populateAdjustmentDropdown(currentRows);
    renderAdjustment();
  }

  [
    startInput,
    endInput,
    baseSalaryInput,
    salaryGrowthInput,
    totalLoeInput,
    fringeRateInput,
    salaryCapInput,
    knownGrantSalaryInput,
    knownGrantLoeInput,
  ].forEach((input) => {
    input?.addEventListener("input", updateTool);
  });

  adjustFySelect?.addEventListener("change", renderAdjustment);
</script>

<style>
