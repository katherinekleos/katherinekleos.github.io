  }

  .table-wrap {
    margin-top: 1.25rem;
    overflow-x: auto;
  }

  .results-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  .wide-table {
    min-width: 1500px;
  }

  .results-table th,
  .results-table td {
    padding: 0.9rem 0.95rem;
    text-align: left;
    border-bottom: 1px solid rgba(38, 78, 65, 0.1);
    vertical-align: top;
  }

  .results-table th {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #4b5d57;
    white-space: nowrap;
  }

  .results-table td {
    color: #223730;
    background: rgba(255, 255, 255, 0.7);
    white-space: nowrap;
  }

