    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .input-grid-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .field span {
    font-size: 0.95rem;
    font-weight: 600;
    color: #29473d;
  }

  .field input,
  .field select {
    width: 100%;
    min-height: 48px;
    padding: 0.8rem 0.95rem;
    border: 1px solid rgba(38, 78, 65, 0.18);
    border-radius: 14px;
    background: #fff;
