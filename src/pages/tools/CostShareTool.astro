    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
  }

  .tool-hero {
    margin-bottom: 2rem;
  }

  .tool-eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5f6f6a;
  }

  .tool-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    color: #1f352d;
  }

