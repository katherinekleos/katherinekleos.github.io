---
import MainLayout from "../../layouts/MainLayout.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { featuredPost, recentPosts } from "../../data/blogPosts";
---

<MainLayout
  title="Blog"
  description="Writing on research administration, systems, tools, and practical workflow design."
>
  <section class="blog-hero section-shell">
    <h1>Writing on structure, tools, and practical systems</h1>
    <p class="intro">
      A space for reflections on research administration, workflow design,
      overlooked tools, and system thinking in practice.
    </p>
  </section>

  <section class="section-shell featured-section">
    <BlogCard
      title={featuredPost.title}
      description={featuredPost.description}
      href={featuredPost.href}
      image={featuredPost.image}
      date={featuredPost.date}
      displayDate={featuredPost.displayDate}
      tags={featuredPost.tags}
      variant="featured"
    />
  </section>

  <section class="section-shell recent-section">
    <h2 class="section-title">Recent</h2>

    <div class="recent-stack">
      {recentPosts.map((post) => (
        <BlogCard
          title={post.title}
          description={post.description}
          href={post.href}
          image={post.image}
          date={post.date}
          displayDate={post.displayDate}
          tags={post.tags}
          variant="recent"
        />
      ))}
    </div>
  </section>
</MainLayout>

<style>
  .section-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .blog-hero {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
    margin-bottom: 1rem;
  }

  .blog-hero h1 {
    margin: 0;
    max-width: 20ch;
    font-size: clamp(2.75rem, 6vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #16342d;
  }

  .intro {
    max-width: 48rem;
    margin: 1.4rem 0 1rem;
    font-size: 1.18rem;
    line-height: 1.7;
    color: #263238;
  }

  .featured-section {
    margin-bottom: 3.25rem;
  }

  .recent-section {
    padding-bottom: 4rem;
  }

  .section-title {
    margin: 0 0 1.2rem;
    font-size: 1.5rem;
    line-height: 1.2;
    color: #16342d;
  }

  .recent-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .blog-hero {
      padding-top: 1.75rem;
      margin-bottom: 2rem;
    }

    .intro {
      font-size: 1.05rem;
    }

    .recent-stack {
      gap: 1.25rem;
    }
  }
</style>