---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const focusAreas = [
  {
    title: "Cost Transfer & Compliance Structuring",
    description:
      "Clear, defensible documentation aligned with institutional policy and Uniform Guidance.",
    accent: "violet",
  },
  {
    title: "Cross-System Financial Validation",
    description:
      "Reviewing and aligning data across enterprise systems to support reporting integrity.",
    accent: "blue",
  },
  {
    title: "Multi-Ledger Reconciliation",
    description:
      "Cross-system validation to ensure financial accuracy and identify discrepancies early.",
    accent: "gold",
  },
  {
    title: "Portfolio Forecasting & Financial Oversight",
    description:
      "Multi-account forecasting, budget alignment, and financial visibility across sponsored projects.",
    accent: "red",
  },
  {
    title: "Post-Award Lifecycle Management",
    description:
      "Oversight of awards from activation through closeout, ensuring continuity and compliance.",
    accent: "green",
  },
];

const tools = [
  {
    title: "Cost Share Tool",
    description:
      "Structured calculator for salary cap planning, cost share allocation, and fiscal year breakdowns across project periods.",
    href: "/tools/cost-share-tool",
    external: false,
    status: "",
    accent: "green",
    icon: "chart",
  },
  {
    title: "Cost Transfer Justification Tool",
    description:
      "Structured support for building clear, policy-aligned cost transfer entries, payroll corrections, and debit-credit balancing.",
    href: "/tools/cost-transfer-justification",
    external: false,
    status: "",
    accent: "red",
    icon: "document",
  },
  {
    title: "LOE Burn Planner",
    description:
      "Planning tool for projecting effort distribution, salary usage, and timing across personnel and sponsored project periods.",
    href: "/tools/loe-burn-planner",
    external: false,
    status: "",
    accent: "blue",
    icon: "tracker",
  },
  {
    title: "Multi-Ledger Reconciliation Checklist",
    description:
      "Repeatable checklist for identifying discrepancies and validating cross-account financial data.",
    href: "#",
    external: false,
    status: "In Development",
    accent: "gold",
    icon: "layers",
  },
  {
    title: "Post-Award Action Tracker",
    description:
      "Centralized structure for monitoring extensions, carryforward, rebudgeting, and lifecycle actions.",
    href: "#",
    external: false,
    status: "In Development",
    accent: "green",
    icon: "tracker",
  },
  {
    title: "Sponsored Portfolio Forecast Model",
    description:
      "Multi-account forecasting tool designed to improve visibility and financial planning across active awards.",
    href: "#",
    external: false,
    status: "In Development",
    accent: "violet",
    icon: "chart",
  },
];

const selectedWork = [
  {
    title: "Geographic Information Systems (GIS)",
    description:
      "Applied spatial analysis and mapping tools to support research, interpretation, and visual communication, with select materials and outputs to be made available.",
    accent: "green",
  },
  {
    title: "Archaeological Fieldwork",
    description:
      "Experience in field-based environments grounded in documentation, material interpretation, and analytical structure.",
    accent: "gold",
  },
  {
    title: "Classical Studies & Languages and Cultures",
    description:
      "Academic training centered on language, institutions, and continuity across historical systems.",
    accent: "red",
  },
  {
    title: "Systems Perspective Across Disciplines",
    description:
      "Ongoing interest in how historical systems and methods of interpretation inform modern organizational thinking.",
    accent: "blue",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="About | Katherine Alexis Gruber" />
  </head>

  <body>
    <Header />

    <main class="about-page">
      <div class="about-shell">
        <section class="about-intro">
          <div class="about-intro__inner">
            <h1 class="about-title">Katherine Alexis Gruber</h1>
            <p class="about-role">Post-Award Specialist | Research Administration &amp; Systems</p>
            <p class="about-positioning">
              Designing structured financial and compliance systems for sponsored research
            </p>

            <div class="about-copy">
              <p>
                Structure is essential in research administration, particularly within sponsored
                research finance. My work centers on bringing clarity to complex systems—supporting
                budgeting, reconciliation, compliance, and closeout. At its core, it is about
                ensuring that what should happen financially is what actually happens.
              </p>

              <p>
                I’m drawn to patterns—where processes repeat, where they break down, and how they
                can be rebuilt more cleanly. Whether forecasting across accounts or refining
                documentation, I approach problems with a systems mindset: simplify, standardize,
                and make the underlying logic visible. My technical background supports this work,
                but the goal is always the same—structures that hold under pressure and scale over
                time.
              </p>

              <p>
                Outside of my current role, my background in Classical Studies and Languages and
                Cultures continues to shape how I think. These fields examine how humans build
                systems—language, institutions, and continuity across time. I carry that
                perspective into my work: designing structures that not only function, but make
                sense to the people who rely on them.
              </p>
            </div>
          </div>
        </section>

        <section class="about-section">
          <div class="about-section__heading">
            <h2>Core Areas of Focus</h2>
          </div>

          <div class="about-grid about-grid--two">
            {focusAreas.map((item) => (
              <article class={`about-info-card about-accent-${item.accent}`}>
                <span class="about-info-card__dot" aria-hidden="true"></span>
                <div class="about-info-card__body">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="about-section">
          <div class="about-section__heading">
            <h2>Experience</h2>
          </div>

          <div class="about-stack">
            <article class="about-feature-card about-accent-blue">
              <div class="about-feature-card__body">
                <div class="about-experience-head">
                  <div class="about-experience-main">
                    <h3>Post-Award Specialist</h3>
                    <p class="about-meta">
                      Research Administrative Service Units, Office of Research · Tulane University
                      · New Orleans, LA
                    </p>
                  </div>
                  <p class="about-date">September 2025 – Present</p>
                </div>

                <p class="about-summary">
                  Oversee post-award financial management across a multi-unit sponsored research
                  portfolio, ensuring compliance, reporting accuracy, and lifecycle continuity.
                </p>

                <div class="about-subblock">
                  <p class="about-label">Key achievements</p>
                  <ul>
                    <li>
                      Lead account reconciliation, labor distribution review, and budget forecasting
                      across active sponsored projects.
                    </li>
                    <li>
                      Advise principal investigators on sponsor regulations, effort certification,
                      and award lifecycle requirements.
                    </li>
                    <li>
                      Manage post-award actions including carryforward, no-cost extensions,
                      rebudgeting, and scope modifications.
                    </li>
                    <li>
                      Support institutional ERP transition through workflow adaptation and reporting
                      validation.
                    </li>
                  </ul>
                </div>
              </div>
            </article>

            <article class="about-feature-card about-accent-green">
              <div class="about-feature-card__body">
                <div class="about-experience-head">
                  <div class="about-experience-main">
                    <h3>Program Manager</h3>
                    <p class="about-meta">
                      Tropical Medicine &amp; Infectious Disease, Celia Scott Weatherhead School of
                      Public Health and Tropical Medicine · Tulane University · New Orleans, LA
                    </p>
                  </div>
                  <p class="about-date">August 2024 – September 2025 · 1 year 1 month</p>
                </div>

                <p class="about-summary">
                  Supported departmental research administration through financial tracking,
                  reporting, and coordination across pre- and post-award functions.
                </p>

                <div class="about-subblock">
                  <p class="about-label">Key achievements</p>
                  <ul>
                    <li>
                      Conducted monthly account reconciliations and expenditure tracking to ensure
                      sponsor compliance.
                    </li>
                    <li>
                      Prepared financial reports for principal investigators to support budget
                      oversight and decision-making.
                    </li>
                    <li>
                      Coordinated personnel and account changes across sponsored projects in
                      alignment with institutional policy.
                    </li>
                    <li>
                      Assisted with invoice preparation and financial documentation for cost
                      reimbursement processes.
                    </li>
                  </ul>
                </div>
              </div>
            </article>
          </div>
        </section>

        <section class="about-section">
          <div class="about-section__heading">
            <h2>Tools &amp; Templates</h2>
          </div>

          <div class="about-grid about-grid--two">
            {tools.map((tool) => {
              const isDevelopment = Boolean(tool.status);

              return (
                <a
                  class={`about-tool-card about-accent-${tool.accent} ${isDevelopment ? "about-tool-card--inactive about-tool-card--development" : ""}`}
                  href={isDevelopment ? undefined : tool.href}
                  target={tool.external && !isDevelopment ? "_blank" : undefined}
                  rel={tool.external && !isDevelopment ? "noreferrer noopener" : undefined}
                  aria-label={isDevelopment ? `${tool.title} in development` : `Open ${tool.title}`}
                  aria-disabled={isDevelopment ? "true" : undefined}
                >
                  <div class="about-tool-card__body">
                    <div class="about-tool-card__top">
                      <div class="about-tool-card__icon-wrap">
                        <div class="about-tool-card__icon">
                          {tool.icon === "document" && (
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="M8 3.5h6l4 4V20a.5.5 0 0 1-.5.5h-9A2.5 2.5 0 0 1 6 18V6a2.5 2.5 0 0 1 2-2.5Z"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linejoin="round"
                              />
                              <path
                                d="M14 3.5V8h4"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linejoin="round"
                              />
                            </svg>
                          )}
                          {tool.icon === "check" && (
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="M9.2 12.8 11.5 15l5.3-6"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.9"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                              <rect
                                x="4"
                                y="4"
                                width="16"
                                height="16"
                                rx="3"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                              />
                            </svg>
                          )}
                          {tool.icon === "layers" && (
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="m12 4 8 4-8 4-8-4 8-4Z"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linejoin="round"
                              />
                              <path
                                d="m4 12 8 4 8-4"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linejoin="round"
                              />
                              <path
                                d="m4 16 8 4 8-4"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linejoin="round"
                              />
                            </svg>
                          )}
                          {tool.icon === "tracker" && (
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="M8 6.5h8M8 12h8M8 17.5h5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                              />
                              <rect
                                x="4"
                                y="3.5"
                                width="16"
                                height="17"
                                rx="3"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                              />
                            </svg>
                          )}
                          {tool.icon === "chart" && (
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                              <path
                                d="M5 19.5h14"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                                stroke-linecap="round"
                              />
                              <path
                                d="M7.5 16V11M12 16V8M16.5 16v-5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                              />
                            </svg>
                          )}
                        </div>
                      </div>

                      <div class="about-tool-card__head">
                        <h3>{tool.title}</h3>
                        {tool.status && <span class="about-status-pill">{tool.status}</span>}
                      </div>
                    </div>

                    <p>{tool.description}</p>

                    {!isDevelopment && (
                      <span class="about-tool-card__link">
                        {tool.external ? "View on GitHub" : "View item"}
                      </span>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </section>

        <section class="about-section">
          <div class="about-section__heading">
            <h2>Selected Work: Archaeology &amp; Classical Studies</h2>
          </div>

          <div class="about-grid about-grid--two">
            {selectedWork.map((item) => (
              <article class={`about-info-card about-accent-${item.accent}`}>
                <span class="about-info-card__dot" aria-hidden="true"></span>
                <div class="about-info-card__body">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="about-section">
          <div class="about-section__heading">
            <h2>Education</h2>
          </div>

          <div class="about-grid about-grid--two">
            <article class="about-info-card about-accent-red">
              <span class="about-info-card__dot" aria-hidden="true"></span>
              <div class="about-info-card__body">
                <h3>Texas Tech University · Lubbock, TX</h3>
                <p class="about-edu-degree">Master of Arts, Languages and Cultures</p>

                <div class="about-subblock about-subblock--compact">
                  <p class="about-label">Experience</p>
                  <ul class="about-edu-list">
                    <li>Athenian Agora Excavations, Volunteer Excavator (Summer 2023)</li>
                    <li>
                      American School of Classical Studies at Athens (ASCSA), Summer Session (2022)
                      — Hill Scholarship (ASCSA); Conference Travel Funding (CMLL); Graduate School
                      Funding (Texas Tech University)
                    </li>
                  </ul>
                </div>
              </div>
            </article>

            <article class="about-info-card about-accent-green">
              <span class="about-info-card__dot" aria-hidden="true"></span>
              <div class="about-info-card__body">
                <h3>Tulane University · New Orleans, LA</h3>
                <p class="about-edu-degree">Bachelor of Arts, Classical Studies</p>
                <p class="about-edu-degree">Certificate in Geographic Information Systems (GIS)</p>

                <div class="about-subblock about-subblock--compact">
                  <p class="about-label">Activities</p>
                  <ul class="about-edu-list">
                    <li>Cookies &amp; Code</li>
                    <li>Tulane HR Internship</li>
                  </ul>
                </div>
              </div>
            </article>
          </div>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(html, body) {
    overflow-x: hidden;
  }

  :global(body) {
    background:
      radial-gradient(circle at 12% 10%, rgba(210, 55, 75, 0.12), transparent 24%),
      radial-gradient(circle at 88% 16%, rgba(67, 122, 255, 0.12), transparent 26%),
      radial-gradient(circle at 78% 82%, rgba(80, 168, 94, 0.12), transparent 24%),
      radial-gradient(circle at 14% 84%, rgba(163, 89, 227, 0.11), transparent 24%),
      radial-gradient(circle at 50% 4%, rgba(235, 178, 70, 0.11), transparent 18%),
      #fbfbfc;
    color: #18212b;
    font-family: Cambria, Georgia, "Times New Roman", serif;
  }

  .about-page {
    width: 100%;
    padding: 2.25rem 1rem 4.5rem;
  }

  .about-shell {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    padding: 1.1rem;
    border-radius: 32px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.96)),
      radial-gradient(circle at top left, rgba(211, 66, 82, 0.12), transparent 28%),
      radial-gradient(circle at top right, rgba(74, 134, 255, 0.12), transparent 30%),
      radial-gradient(circle at bottom right, rgba(88, 173, 99, 0.12), transparent 28%),
      radial-gradient(circle at bottom left, rgba(161, 95, 226, 0.11), transparent 28%);
    box-shadow:
      0 20px 60px rgba(24, 33, 43, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .about-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 32px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(214, 73, 83, 0.34),
      rgba(232, 186, 75, 0.26),
      rgba(74, 157, 110, 0.28),
      rgba(78, 125, 255, 0.26),
      rgba(164, 94, 226, 0.28)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .about-intro,
  .about-section {
    position: relative;
    z-index: 1;
  }

  .about-intro {
    margin-bottom: 2.15rem;
  }

  .about-intro__inner {
    border-radius: 26px;
    padding: 2.4rem 2rem 2.15rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 255, 255, 0.93)),
      radial-gradient(circle at 6% 0%, rgba(220, 77, 94, 0.08), transparent 22%),
      radial-gradient(circle at 94% 4%, rgba(71, 124, 255, 0.08), transparent 22%);
    border: 1px solid rgba(27, 39, 54, 0.08);
    box-shadow:
      0 22px 44px rgba(24, 33, 43, 0.07),
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
    text-align: center;
  }

  .about-title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.15rem);
    line-height: 1.05;
    color: #18212b;
  }

  .about-role {
    margin: 0.8rem auto 0;
    max-width: 780px;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #243241;
  }

  .about-positioning {
    margin: 0.7rem auto 0;
    max-width: 760px;
    font-size: 0.99rem;
    color: #5b6571;
    font-style: italic;
  }

  .about-copy {
    max-width: 800px;
    margin: 1.7rem auto 0;
    text-align: left;
  }

  .about-copy p {
    margin: 0 0 1.1rem;
    font-size: 1.02rem;
    line-height: 1.8;
    color: #263341;
  }

  .about-copy p:last-child {
    margin-bottom: 0;
  }

  .about-section {
    margin-top: 2rem;
  }

  .about-section__heading {
    margin-bottom: 1rem;
    padding-left: 0.15rem;
  }

  .about-section__heading h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.8rem);
    color: #18212b;
  }

  .about-grid {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .about-grid--two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-stack {
    display: grid;
    gap: 1rem;
  }

  .about-info-card,
  .about-feature-card,
  .about-tool-card {
    position: relative;
    min-width: 0;
    border-radius: 22px;
    border: 1px solid rgba(27, 39, 54, 0.08);
    overflow: hidden;
  }

  .about-info-card,
  .about-feature-card {
    background: rgba(255, 255, 255, 0.92);
    box-shadow:
      0 16px 34px rgba(24, 33, 43, 0.07),
      0 1px 0 rgba(255, 255, 255, 0.82) inset;
    transition:
      box-shadow 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .about-info-card::after,
  .about-feature-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .about-info-card:hover,
  .about-feature-card:hover {
    border-color: rgba(27, 39, 54, 0.12);
    transform: none;
  }

  .about-info-card:hover::after,
  .about-feature-card:hover::after {
    opacity: 1;
  }

  .about-tool-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.94);
    box-shadow:
      0 16px 34px rgba(24, 33, 43, 0.07),
      0 1px 0 rgba(255, 255, 255, 0.82) inset;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
    will-change: transform;
  }

  .about-tool-card:hover,
  .about-tool-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(27, 39, 54, 0.12);
    outline: none;
  }

  .about-tool-card--inactive {
    cursor: default;
  }

  .about-tool-card--inactive:hover,
  .about-tool-card--inactive:focus-visible {
    transform: none !important;
  }

  .about-tool-card--development {
    background: rgba(255, 255, 255, 0.92);
    box-shadow:
      0 16px 34px rgba(24, 33, 43, 0.07),
      0 1px 0 rgba(255, 255, 255, 0.82) inset;
    transition:
      box-shadow 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .about-info-card__body,
  .about-tool-card__body {
    position: relative;
    z-index: 1;
    padding: 1.2rem 1.2rem 1.1rem;
  }

  .about-feature-card__body {
    position: relative;
    z-index: 1;
    padding: 1.5rem 1.4rem 1.35rem;
  }

  .about-info-card__body {
    padding-top: 2.1rem;
  }

  .about-info-card h3,
  .about-feature-card h3,
  .about-tool-card h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.35;
    color: #19232d;
  }

  .about-info-card p,
  .about-feature-card p,
  .about-tool-card p {
    margin: 0.65rem 0 0;
    color: #44515e;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .about-info-card__dot {
    position: absolute;
    top: 1rem;
    left: 1rem;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.82);
    z-index: 2;
  }

  .about-tool-card__top {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .about-tool-card__head {
    min-width: 0;
    flex: 1;
  }

  .about-tool-card__icon-wrap {
    flex: 0 0 auto;
    padding-top: 0.05rem;
  }

  .about-tool-card__icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 14px;
    color: #18212b;
    border: 1px solid rgba(27, 39, 54, 0.08);
    box-shadow:
      0 10px 24px rgba(24, 33, 43, 0.07),
      0 1px 0 rgba(255, 255, 255, 0.9) inset;
  }

  .about-tool-card__icon svg {
    width: 20px;
    height: 20px;
  }

  .about-status-pill {
    display: inline-flex;
    margin-top: 0.45rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
